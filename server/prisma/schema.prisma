generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  super_admin
  admin
  receptionist
  consultant
  customer
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String?
  password   String

  role       Role     @default(consultant)

  branchId   String?
  branch     Branch?  @relation(fields: [branchId], references: [id])

  tickets    Ticket[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}